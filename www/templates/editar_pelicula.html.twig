<h1>Editar Película</h1>
<form method="post" enctype="multipart/form-data">
  <label>Título:</label><br>
  <input type="text" name="titulo" value="{{ pelicula.titulo }}"><br>

  <label>Director:</label><br>
  <input type="text" name="director" value="{{ pelicula.director }}"><br>

  <label>Fecha:</label><br>
  <input type="date" name="fecha" value="{{ pelicula.fecha }}"><br>

  <label>Descripción:</label><br>
  <textarea name="descripcion">{{ pelicula.descripcion }}</textarea><br>

  <label>Actualizar imagen de portada:</label><br>
  <input type="file" name="imagen"><br>

  <button type="submit">Guardar cambios</button>
</form>

<h3>Hashtags actuales:</h3>
<ul>
  {% for h in hashtags %}
    <li>
      #{{ h }} 
      <a href="eliminar_hashtag.php?id_pelicula={{ id }}&hashtag={{ h }}">x</a>
    </li>
  {% endfor %}
</ul>

<h4>Añadir nuevo hashtag:</h4>
<form method="post" action="añadir_hashtag.php">
  <input type="hidden" name="id_pelicula" value="{{ id }}">
  <input type="text" name="nombre_hashtag" placeholder="ej: drama">
  <button type="submit">➕ Añadir</button>
</form>

<a href="gestionar_peliculas.php">Atrás</a>

